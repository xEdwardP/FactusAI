generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Cliente {
  id         BigInt   @id @default(autoincrement())
  Nombre     String?  @db.VarChar
  created_at DateTime @default(now()) @db.Timestamptz(6)
}


enum EstadoUsuario {
  Activo
  Inactivo
  Suspendido
}

enum TipoFactura {
  Credito
  Contado
}

enum TipoMovimiento {
  Ingreso
  Gasto
}

enum MedioEnvio {
  Email
  WhatsApp
  Otro
}

enum EstadoEnvio {
  Enviado
  Fallido
  Entregado
}

// ============================================================
// EMPRESA
// Organización o negocio al que pertenecen las facturas
// ============================================================

model Empresa {
  id        Int      @id @default(autoincrement()) @map("id_empresa")
  nombre    String   @db.VarChar(150)
  ruc       String?  @unique @db.VarChar(20)
  correo    String?  @db.VarChar(150)
  telefono  String?  @db.VarChar(20)
  direccion String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  usuarios  UsuarioEmpresa[]
  facturas  Factura[]

  @@map("empresa")
}

// ============================================================
// USUARIO
// Usuarios del sistema con acceso autenticado
// ============================================================

model Usuario {
  id           Int          @id @default(autoincrement()) @map("id_usuario")
  identificador String      @unique @db.VarChar(20)
  nombre       String       @db.VarChar(100)
  correo       String       @unique @db.VarChar(150)
  contrasena   String       @db.VarChar(255) @map("contraseña")
  estado       EstadoUsuario @default(Activo)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relaciones
  facturas     Factura[]
  empresas     UsuarioEmpresa[]
  envios       DetalleEnvio[]

  @@map("usuario")
}

// ============================================================
// USUARIO_EMPRESA
// Relación muchos a muchos entre Usuario y Empresa
// Un usuario puede pertenecer a varias empresas
// ============================================================

model UsuarioEmpresa {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("id_usuario")
  empresaId Int      @map("id_empresa")
  createdAt DateTime @default(now())

  // Relaciones
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  empresa   Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([usuarioId, empresaId])
  @@map("usuario_empresa")
}

// ============================================================
// CATEGORIA_GASTO
// Catálogo de categorías: Alimentación, Transporte, Salud, etc.
// ============================================================

model CategoriaGasto {
  id          Int      @id @default(autoincrement()) @map("id_categoria_gasto")
  nombre      String   @db.VarChar(100)
  descripcion String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  facturas    Factura[]

  @@map("categoria_gasto")
}

// ============================================================
// TIPO_DOCUMENTO
// Catálogo: Factura, Recibo, Nota de Crédito, etc.
// ============================================================

model TipoDocumento {
  id       Int       @id @default(autoincrement()) @map("id_tipo_documento")
  nombre   String    @db.VarChar(50)

  // Relaciones
  facturas Factura[]

  @@map("tipo_documento")
}

// ============================================================
// FACTURA
// Registro principal de facturas de gastos o ingresos
// ============================================================

model Factura {
  id              Int            @id @default(autoincrement()) @map("id_factura")
  fecha           DateTime       @db.Date
  proveedor       String         @db.VarChar(150)
  monto           Decimal        @db.Decimal(12, 2)
  imagen          String?        @db.VarChar(255)
  facturaFisica   Boolean        @default(false) @map("factura_fisica")
  tipoFactura     TipoFactura    @map("id_tipo_factura")
  tipoMovimiento  TipoMovimiento @map("ingreso_gasto")
  observaciones   String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Llaves foráneas
  usuarioId       Int            @map("id_usuario")
  empresaId       Int            @map("id_empresa")
  categoriaGastoId Int           @map("id_categoria_gasto")
  tipoDocumentoId Int            @map("id_tipo_documento")

  // Relaciones
  usuario         Usuario        @relation(fields: [usuarioId], references: [id])
  empresa         Empresa        @relation(fields: [empresaId], references: [id])
  categoriaGasto  CategoriaGasto @relation(fields: [categoriaGastoId], references: [id])
  tipoDocumento   TipoDocumento  @relation(fields: [tipoDocumentoId], references: [id])
  envios          DetalleEnvioFactura[]

  @@map("factura")
}

// ============================================================
// DETALLE_ENVIO
// Historial de envíos de facturas a contadora u otros
// ============================================================

model DetalleEnvio {
  id           Int         @id @default(autoincrement()) @map("id_detalle_envio")
  timestamp    DateTime    @default(now())
  destinatario String      @db.VarChar(150)
  medioEnvio   MedioEnvio  @map("medio_envio")
  estado       EstadoEnvio @default(Enviado)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Llaves foráneas
  usuarioId    Int         @map("id_usuario")

  // Relaciones
  usuario      Usuario     @relation(fields: [usuarioId], references: [id])
  facturas     DetalleEnvioFactura[]

  @@map("detalle_envio")
}

// ============================================================
// DETALLE_ENVIO_FACTURA
// Relación muchos a muchos entre DetalleEnvio y Factura
// Un envío puede incluir múltiples facturas
// ============================================================

model DetalleEnvioFactura {
  id             Int          @id @default(autoincrement())
  detalleEnvioId Int          @map("id_detalle_envio")
  facturaId      Int          @map("id_factura")

  // Relaciones
  detalleEnvio   DetalleEnvio @relation(fields: [detalleEnvioId], references: [id])
  factura        Factura      @relation(fields: [facturaId], references: [id])

  @@unique([detalleEnvioId, facturaId])
  @@map("detalle_envio_factura")
}

